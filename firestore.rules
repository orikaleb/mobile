rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Dev-oriented: debug seed writes routes/cities/seats before any sign-in.
    // Replace route/city/seat write-all with Cloud Functions or admin-only rules for production.
    match /routes/{routeId} {
      allow read: if true;
      allow write: if true;
      match /seats/{seatId} {
        allow read: if true;
        allow write: if true;
      }
    }
    match /cities/{cityId} {
      allow read: if true;
      allow write: if true;
    }
    match /bookings/{bookingId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /users/{userId} {
      // Split read/write so first-time profile create is clearly allowed for the signed-in uid.
      allow get, list: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null && request.auth.uid == userId;
      match /payment_methods/{pmId} {
        allow get, list: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    match /notifications/{notifId} {
      allow read, update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
