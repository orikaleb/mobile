rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────
    // Admin allow-list — keep in sync with AdminConfig.adminEmails
    // in the Android app. Emails are compared case-insensitively.
    // ─────────────────────────────────────────────────────────────
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
          'admin@nexiride.com',
          'kalebotchere@gmail.com'
        ];
    }

    // Dev-oriented: debug seed writes routes/cities/seats before any sign-in.
    // Replace route/city/seat write-all with Cloud Functions or admin-only rules for production.
    match /routes/{routeId} {
      allow read: if true;
      allow write: if true;
      match /seats/{seatId} {
        allow read: if true;
        allow write: if true;
      }
    }
    match /cities/{cityId} {
      allow read: if true;
      allow write: if true;
    }
    match /bookings/{bookingId} {
      // Admins can list/read every booking; regular users only see their own.
      allow list: if isAdmin();
      allow get: if isAdmin()
        || (request.auth != null && request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAdmin()
        || (request.auth != null && request.auth.uid == resource.data.userId);
    }
    match /users/{userId} {
      // Admins can list/read every user profile; owner keeps write access.
      allow list: if isAdmin();
      allow get: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);
      match /payment_methods/{pmId} {
        allow get, list: if isAdmin()
          || (request.auth != null && request.auth.uid == userId);
        allow create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }
    match /notifications/{notifId} {
      // Admins can list all notifications and broadcast to any user (create for others).
      allow list: if isAdmin();
      allow get: if isAdmin()
        || (request.auth != null && request.auth.uid == resource.data.userId);
      allow create: if isAdmin()
        || (request.auth != null && request.auth.uid == request.resource.data.userId);
      allow update, delete: if isAdmin()
        || (request.auth != null && request.auth.uid == resource.data.userId);
    }
    // Bus driver accounts. Doc id MUST equal the driver's Firebase Auth uid.
    // The driver can self-register and update non-admin fields; the admin has
    // full CRUD (including toggling `active` and reassigning `assignedBusId`).
    match /drivers/{driverId} {
      allow list: if isAdmin();
      allow get: if isAdmin()
        || (request.auth != null && request.auth.uid == driverId);
      allow create: if request.auth != null && request.auth.uid == driverId;
      allow update, delete: if isAdmin()
        || (request.auth != null && request.auth.uid == driverId);
    }
    // Registered fleet buses. Any signed-in user can read (drivers need to see
    // which bus they're assigned to) but only admins can create/modify/delete.
    match /buses/{busId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }
  }
}
