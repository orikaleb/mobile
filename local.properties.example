# Copy to local.properties (Android Studio creates this file; it is gitignored).

sdk.dir=/path/to/Android/sdk

# Firebase: add the Android app in Firebase Console and download google-services.json
# into app/ (replace the committed placeholder). Enable Email/Password under Authentication.

# Google Maps SDK: create an API key with "Maps SDK for Android" enabled, restrict by package
# com.example.nexiride2 + SHA-1, then:
# MAPS_API_KEY=your_key_here
